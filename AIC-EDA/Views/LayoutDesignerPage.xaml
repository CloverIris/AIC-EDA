<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AIC_EDA.Views.LayoutDesignerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AIC_EDA.Models"
    xmlns:vm="using:AIC_EDA.ViewModels"
    mc:Ignorable="d"
    Background="{StaticResource SurfaceDarkBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="260"/>
        </Grid.ColumnDefinitions>

        <!-- Header / Toolbar -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                Background="{StaticResource SurfaceCardBrush}"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="[ LAYOUT_DESIGNER ]" Style="{StaticResource BracketTagStyle}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusTextBlock" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <ComboBox x:Name="GridSizeCombo" Width="80" Height="28" FontSize="11" SelectionChanged="GridSizeCombo_SelectionChanged">
                        <ComboBoxItem Content="20 px" Tag="20"/>
                        <ComboBoxItem Content="30 px" Tag="30" IsSelected="True"/>
                        <ComboBoxItem Content="40 px" Tag="40"/>
                        <ComboBoxItem Content="50 px" Tag="50"/>
                    </ComboBox>
                    <Button Style="{StaticResource EndfieldGhostButtonStyle}" Padding="8,4" Click="ImportFromGraph_Click" ToolTipService.ToolTip="Import from Compiled Graph">
                        <FontIcon Glyph="&#xE8B0;" FontSize="14" Foreground="{StaticResource AccentGreenBrush}"/>
                    </Button>
                    <Border Width="1" Background="{StaticResource BorderDefaultBrush}" Margin="4,2"/>
                    <Button Style="{StaticResource EndfieldGhostButtonStyle}" Padding="8,4" Click="SaveLayout_Click" ToolTipService.ToolTip="Save Layout">
                        <FontIcon Glyph="&#xE792;" FontSize="14" Foreground="{StaticResource AccentCyanBrush}"/>
                    </Button>
                    <Button Style="{StaticResource EndfieldGhostButtonStyle}" Padding="8,4" Click="LoadLayout_Click" ToolTipService.ToolTip="Load Layout">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14" Foreground="{StaticResource AccentCyanBrush}"/>
                    </Button>
                    <Border Width="1" Background="{StaticResource BorderDefaultBrush}" Margin="4,2"/>
                    <Button Style="{StaticResource EndfieldGhostButtonStyle}" Padding="8,4" Click="ClearLayout_Click" ToolTipService.ToolTip="Clear All">
                        <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>
                    <Button Style="{StaticResource EndfieldGhostButtonStyle}" Padding="8,4" Click="ZoomIn_Click" ToolTipService.ToolTip="Zoom In">
                        <FontIcon Glyph="&#xE8A3;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>
                    <Button Style="{StaticResource EndfieldGhostButtonStyle}" Padding="8,4" Click="ZoomOut_Click" ToolTipService.ToolTip="Zoom Out">
                        <FontIcon Glyph="&#xE71F;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>
                    <Button Style="{StaticResource EndfieldGhostButtonStyle}" Padding="8,4" Click="ZoomReset_Click" ToolTipService.ToolTip="Reset View">
                        <FontIcon Glyph="&#xE81C;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>
                    <Border Width="1" Background="{StaticResource BorderDefaultBrush}" Margin="4,2"/>
                    <ToggleButton x:Name="IsometricToggle" Padding="8,4" Background="Transparent" BorderThickness="0" Click="IsometricToggle_Click" ToolTipService.ToolTip="Toggle Isometric View">
                        <FontIcon Glyph="&#xE809;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </ToggleButton>
                    <Border Width="1" Background="{StaticResource BorderDefaultBrush}" Margin="4,2"/>
                    <ToggleButton x:Name="ShowPowerRadiusToggle" Padding="8,4" Background="Transparent" BorderThickness="0" Click="ShowPowerRadiusToggle_Click" ToolTipService.ToolTip="Show All Power Radii">
                        <FontIcon Glyph="&#xE945;" FontSize="14" Foreground="{StaticResource AccentOrangeBrush}"/>
                    </ToggleButton>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Left: Machine Palette -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource SurfaceCardBrush}"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,1,0"
                Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <TextBlock Text="MACHINE PALETTE" Style="{StaticResource CaptionLabelStyle}"/>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.PaletteGroups}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:MachinePaletteGroup">
                                <StackPanel Spacing="4" Margin="0,0,0,8">
                                    <TextBlock Text="{x:Bind Name}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <ItemsRepeater ItemsSource="{x:Bind Machines}">
                                        <ItemsRepeater.Layout>
                                            <StackLayout Orientation="Vertical" Spacing="2"/>
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="models:MachineType">
                                                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                        Padding="8,6"
                                                        Background="{StaticResource SurfaceElevatedBrush}"
                                                        BorderThickness="0"
                                                        CornerRadius="4"
                                                        Click="PaletteMachine_Click"
                                                        Tag="{x:Bind}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon Glyph="&#xE7C5;" FontSize="14" Foreground="{StaticResource AccentYellowBrush}"/>
                                                        <TextBlock x:Name="MachineTypeNameText" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" Loaded="MachineTypeNameText_Loaded" Tag="{x:Bind}"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Center: Canvas -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="{StaticResource SurfaceDarkBrush}"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <ScrollViewer x:Name="CanvasScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              ZoomMode="Disabled">
                    <Canvas x:Name="DesignCanvas"
                            Background="Transparent"
                            PointerPressed="Canvas_PointerPressed"
                            PointerMoved="Canvas_PointerMoved"
                            PointerReleased="Canvas_PointerReleased"
                            PointerWheelChanged="Canvas_PointerWheelChanged">
                        <!-- Grid lines drawn in code-behind -->
                    </Canvas>
                </ScrollViewer>

                <!-- Floating stats -->
                <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                        Margin="12" Padding="10,6"
                        Background="{StaticResource SurfaceCardBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Opacity="0.9">
                    <StackPanel Spacing="2">
                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Consolas">
                            <Run Text="Machines: "/><Run Text="{x:Bind ViewModel.MachineCount, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="{x:Bind ViewModel.CategorySummary, Mode=OneWay}" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" FontFamily="Consolas"/>
                        <TextBlock x:Name="CanvasInfoText" Text="Grid: 30px | Zoom: 100%" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" FontFamily="Consolas"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Right: Properties Panel -->
        <Border Grid.Row="1" Grid.Column="2"
                Background="{StaticResource SurfaceCardBrush}"
                Padding="16">
            <StackPanel Spacing="12">
                <TextBlock Text="PROPERTIES" Style="{StaticResource CaptionLabelStyle}"/>

                <!-- No selection state -->
                <StackPanel x:Name="NoSelectionPanel" Spacing="8" HorizontalAlignment="Center" Margin="0,40">
                    <FontIcon Glyph="&#xE7C5;" FontSize="32" Foreground="{StaticResource TextDisabledBrush}"/>
                    <TextBlock Text="No machine selected" FontSize="12" Foreground="{StaticResource TextDisabledBrush}" TextAlignment="Center"/>
                    <TextBlock Text="Select a machine on the canvas or place a new one" FontSize="10" Foreground="{StaticResource TextDisabledBrush}" TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Selected machine properties -->
                <StackPanel x:Name="PropertiesPanel" Spacing="10" Visibility="Collapsed">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE7C5;" FontSize="36" Foreground="{StaticResource AccentYellowBrush}"/>
                        <TextBlock x:Name="PropNameText" Text="Machine Name" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" TextAlignment="Center"/>
                        <TextBlock x:Name="PropCategoryText" Text="Category" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center"/>
                    </StackPanel>

                    <Border Height="1" Background="{StaticResource BorderDefaultBrush}" Margin="0,4"/>

                    <Grid ColumnSpacing="8" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Position" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="PropPositionText" Grid.Row="0" Grid.Column="1" Text="(0, 0)" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Size" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="PropSizeText" Grid.Row="1" Grid.Column="1" Text="2x2" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Rotation" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="PropRotationText" Grid.Row="2" Grid.Column="1" Text="0 degrees" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Power" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="PropPowerText" Grid.Row="3" Grid.Column="1" Text="15 m" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas" VerticalAlignment="Center"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderDefaultBrush}" Margin="0,4"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="CONTROLS" Style="{StaticResource CaptionLabelStyle}"/>
                        <Button Content="Rotate (R)" Click="Rotate_Click" Style="{StaticResource EndfieldButtonStyle}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        <Grid ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="&#x2190;" Click="MoveLeft_Click" Style="{StaticResource EndfieldGhostButtonStyle}" HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="1" Content="&#x2191;" Click="MoveUp_Click" Style="{StaticResource EndfieldGhostButtonStyle}" HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="2" Content="&#x2192;" Click="MoveRight_Click" Style="{StaticResource EndfieldGhostButtonStyle}" HorizontalAlignment="Stretch"/>
                        </Grid>
                        <Button Content="&#x2193;" Click="MoveDown_Click" Style="{StaticResource EndfieldGhostButtonStyle}" HorizontalAlignment="Stretch" Width="80"/>
                        <Button Content="Delete (Del)" Click="Delete_Click" Style="{StaticResource EndfieldButtonStyle}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#5C2B2B"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#7A3A3A"/>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
