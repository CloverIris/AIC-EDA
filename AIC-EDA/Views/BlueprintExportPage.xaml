<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AIC_EDA.Views.BlueprintExportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AIC_EDA.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="Tape-Deploy (部署流片)" Style="{StaticResource TitleLargeTextBlockStyle}"/>
            <TextBlock Text="蓝图编解码与导出 - 类比IC设计的GDSII交付" Opacity="0.7"/>
        </StackPanel>

        <!-- 操作区 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <Button x:Name="ExportBlueprintBtn" Content="导出蓝图" Click="ExportBlueprint_Click" Style="{StaticResource AccentButtonStyle}"/>
            <Button x:Name="ExportJsonBtn" Content="导出JSON" Click="ExportJson_Click"/>
            <Button x:Name="CopyToClipboardBtn" Content="复制到剪贴板" Click="CopyToClipboard_Click"/>
        </StackPanel>

        <!-- 状态 -->
        <InfoBar x:Name="StatusInfoBar"
                 Grid.Row="2"
                 IsOpen="False"
                 Margin="0,0,0,12"/>

        <!-- 预览区 -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" Margin="0,0,8,0">
                <StackPanel Spacing="8">
                    <TextBlock Text="蓝图字符串" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBox x:Name="BlueprintTextBox"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="200"
                             FontFamily="Consolas"
                             FontSize="11"/>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="1" Margin="8,0,0,0">
                <StackPanel Spacing="8">
                    <TextBlock Text="统计信息" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <Grid BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                          BorderThickness="1" 
                          CornerRadius="8"
                          Padding="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="目标产物" Opacity="0.6"/>
                        <TextBlock x:Name="TargetItemText" Grid.Column="1" Text="-"/>

                        <TextBlock Grid.Row="1" Text="目标速率" Opacity="0.6"/>
                        <TextBlock x:Name="TargetRateText" Grid.Row="1" Grid.Column="1" Text="-"/>

                        <TextBlock Grid.Row="2" Text="设备数量" Opacity="0.6"/>
                        <TextBlock x:Name="MachineCountText" Grid.Row="2" Grid.Column="1" Text="-"/>

                        <TextBlock Grid.Row="3" Text="传送带数量" Opacity="0.6"/>
                        <TextBlock x:Name="BeltCountText" Grid.Row="3" Grid.Column="1" Text="-"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
