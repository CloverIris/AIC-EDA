<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AIC_EDA.Views.LayoutPreviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AIC_EDA.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" Background="{StaticResource SurfaceDarkBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="[ FLOORPLAN_EF ]" Style="{StaticResource BracketTagStyle}"/>
            <TextBlock Text="FloorPlan &amp; Place" Style="{StaticResource SectionTitleStyle}"/>
            <TextBlock Text="2D/3D 工厂布局预览与优化 — 网格化设备摆放、传送带路由、电力网络覆盖" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Floating Toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4"
                        Background="{StaticResource SurfaceCardBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="4">
                <Button Style="{StaticResource EndfieldGhostButtonStyle}" Padding="8,4" Click="RefreshLayout_Click" ToolTipService.ToolTip="重新布局">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                </Button>
                <Button Style="{StaticResource EndfieldGhostButtonStyle}" Padding="8,4" Click="ZoomIn_Click" ToolTipService.ToolTip="放大">
                    <FontIcon Glyph="&#xE8A3;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                </Button>
                <Button Style="{StaticResource EndfieldGhostButtonStyle}" Padding="8,4" Click="ZoomOut_Click" ToolTipService.ToolTip="缩小">
                    <FontIcon Glyph="&#xE71F;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                </Button>
                <Button Style="{StaticResource EndfieldGhostButtonStyle}" Padding="8,4" Click="ZoomReset_Click" ToolTipService.ToolTip="重置视图">
                    <FontIcon Glyph="&#xE81C;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                </Button>
                <Border Width="1" Background="{StaticResource BorderDefaultBrush}" Margin="4,2"/>
                <ToggleButton x:Name="ShowConnectionsToggle" IsChecked="True" Padding="8,4" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="显示传送带">
                    <FontIcon Glyph="&#xE8AB;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                </ToggleButton>
                <ToggleButton x:Name="ShowGridToggle" IsChecked="True" Padding="8,4" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="显示网格">
                    <FontIcon Glyph="&#xE80A;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                </ToggleButton>
                <ToggleButton x:Name="ShowLabelsToggle" IsChecked="True" Padding="8,4" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="显示标签">
                    <FontIcon Glyph="&#xE8D2;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                </ToggleButton>
                <Border Width="1" Background="{StaticResource BorderDefaultBrush}" Margin="4,2"/>
                <!-- Grid size selector -->
                <ComboBox x:Name="GridSizeCombo" Width="90" Height="28" FontSize="11"
                          Background="Transparent" BorderThickness="1"
                          SelectionChanged="GridSizeCombo_SelectionChanged">
                    <ComboBoxItem Content="40 px" Tag="40"/>
                    <ComboBoxItem Content="70 px" Tag="70"/>
                </ComboBox>
            </StackPanel>

            <!-- Info text -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock x:Name="GridInfoText" Text="Grid: 40 px" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" FontFamily="Consolas"/>
                <TextBlock x:Name="ZoomText" Text="Zoom: 100%" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" FontFamily="Consolas"/>
                <TextBlock x:Name="StatsText" Text="0 nodes" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" FontFamily="Consolas"/>
            </StackPanel>
        </Grid>

        <!-- Legend -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Rectangle Width="12" Height="12" Fill="#1E90FF" RadiusX="2" RadiusY="2"/>
                    <TextBlock Text="资源" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Rectangle Width="12" Height="12" Fill="#FFA500" RadiusX="2" RadiusY="2"/>
                    <TextBlock Text="加工" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Rectangle Width="12" Height="12" Fill="#808080" RadiusX="2" RadiusY="2"/>
                    <TextBlock Text="物流" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Rectangle Width="12" Height="12" Fill="#FFD700" RadiusX="2" RadiusY="2"/>
                    <TextBlock Text="电力" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Rectangle Width="12" Height="12" Fill="#32CD32" RadiusX="2" RadiusY="2"/>
                    <TextBlock Text="农业" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Canvas Area -->
        <Border Grid.Row="3"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Background="{StaticResource SurfaceCardBrush}">
            <Grid>
                <!-- Main Canvas -->
                <Canvas x:Name="LayoutCanvas"
                        Background="Transparent"
                        PointerPressed="Canvas_PointerPressed"
                        PointerMoved="Canvas_PointerMoved"
                        PointerReleased="Canvas_PointerReleased"
                        PointerWheelChanged="Canvas_PointerWheelChanged"
                        SizeChanged="Canvas_SizeChanged"/>

                <!-- Placeholder -->
                <StackPanel x:Name="PlaceholderPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <FontIcon Glyph="&#xE7BF;" FontSize="48" Foreground="{StaticResource TextDisabledBrush}"/>
                    <TextBlock Text="请先前往 RTL Synthesis 页面编译生产图"
                               FontSize="14"
                               Foreground="{StaticResource TextDisabledBrush}"/>
                    <TextBlock Text="Compile a production graph to visualize the factory layout"
                               FontSize="11"
                               Foreground="{StaticResource TextDisabledBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
