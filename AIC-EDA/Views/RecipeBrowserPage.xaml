<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AIC_EDA.Views.RecipeBrowserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AIC_EDA.Models"
    mc:Ignorable="d">
    <Grid Background="{StaticResource SurfaceDarkBrush}" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="[ RECIPE_BROWSER ]" Style="{StaticResource BracketTagStyle}" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" FontFamily="Consolas">
                    <Run Text="Items: "/><Run Text="{x:Bind ViewModel.Items.Count, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}"/>
                </TextBlock>
                <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" FontFamily="Consolas">
                    <Run Text="Recipes: "/><Run Text="{x:Bind ViewModel.Recipes.Count, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}"/>
                </TextBlock>
            </StackPanel>
        </Grid>
        <TextBox Grid.Row="1" Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                 PlaceholderText="Search..." Margin="0,12"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <Button Content="All" x:Name="FilterAllButton" Click="FilterAll_Click" Style="{StaticResource FilterChipStyle}"/>
            <Button Content="Raw" Click="FilterRaw_Click" Style="{StaticResource FilterChipStyle}"/>
            <Button Content="Intermediate" Click="FilterIntermediate_Click" Style="{StaticResource FilterChipStyle}"/>
            <Button Content="Final" Click="FilterFinal_Click" Style="{StaticResource FilterChipStyle}"/>
            <Button Content="Fluid" Click="FilterFluid_Click" Style="{StaticResource FilterChipStyle}"/>
            <Button Content="Special" Click="FilterSpecial_Click" Style="{StaticResource FilterChipStyle}"/>
        </StackPanel>
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource EndfieldCardStyle}" Margin="0,0,16,0" Padding="12">
                <GridView x:Name="ItemsGridView"
                          ItemsSource="{x:Bind ViewModel.Items}" SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
                          Style="{StaticResource EndfieldGridViewStyle}"
                          ItemContainerStyle="{StaticResource EndfieldRecipeCardStyle}"
                          SelectionMode="Single"
                          IsItemClickEnabled="True"
                          ItemClick="ItemsGridView_ItemClick">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:Item">
                            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <FontIcon Grid.Row="0" Glyph="{Binding IconGlyph}" FontSize="32"
                                          Foreground="{Binding CategoryColorBrush}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="2" Text="{Binding CategoryLabel}" FontSize="9"
                                           Foreground="{StaticResource TextTertiaryBrush}" TextAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Border>
            <StackPanel Grid.Column="1" Spacing="12">
                <Border Background="{StaticResource SurfaceCardBrush}" Padding="16" CornerRadius="4">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <FontIcon Glyph="{x:Bind ViewModel.SelectedItem.IconGlyph, Mode=OneWay, FallbackValue=''}"
                                  FontSize="48" Foreground="{x:Bind ViewModel.SelectedItem.CategoryColorBrush, Mode=OneWay}"/>
                        <TextBlock Text="{x:Bind ViewModel.SelectedItem.Name, Mode=OneWay, FallbackValue='Select an item'}"
                                   FontSize="16" FontWeight="Bold" TextAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.SelectedItem.NameEN, Mode=OneWay, FallbackValue=''}"
                                   FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" TextAlignment="Center"/>
                        <Border Background="{StaticResource SurfaceElevatedBrush}" CornerRadius="4" Padding="8,4" HorizontalAlignment="Center">
                            <TextBlock Text="{x:Bind ViewModel.SelectedItem.CategoryLabel, Mode=OneWay, FallbackValue=''}"
                                       FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Border>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource SurfaceCardBrush}" Padding="0" CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource SurfaceElevatedBrush}" Padding="12,8" CornerRadius="4,4,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="PRODUCTION RECIPES" Style="{StaticResource CaptionLabelStyle}" VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
                                    <Run Text="("/><Run Text="{x:Bind ViewModel.ItemRecipes.Count, Mode=OneWay}"/><Run Text=")"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.ItemRecipes}" Background="Transparent" BorderThickness="0"
                                  ItemContainerStyle="{StaticResource EndfieldListViewItemStyle}" MaxHeight="200">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Recipe">
                                    <Grid Padding="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                                            <TextBlock Text="{x:Bind Machine}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
                                                <Run Text="("/><Run Text="{x:Bind Duration}"/><Run Text="s)"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                                            <TextBlock FontSize="10" Foreground="{StaticResource AccentCyanBrush}">
                                                <Run Text="In: "/><Run Text="{x:Bind InputSummary}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="10" Foreground="{StaticResource AccentGreenBrush}">
                                                <Run Text="Out: "/><Run Text="{x:Bind OutputSummary}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
                <Border Background="{StaticResource SurfaceCardBrush}" Padding="0" CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource SurfaceElevatedBrush}" Padding="12,8" CornerRadius="4,4,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="USED AS INPUT IN" Style="{StaticResource CaptionLabelStyle}" VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
                                    <Run Text="("/><Run Text="{x:Bind ViewModel.ItemUsages.Count, Mode=OneWay}"/><Run Text=")"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.ItemUsages}" Background="Transparent" BorderThickness="0"
                                  ItemContainerStyle="{StaticResource EndfieldListViewItemStyle}" MaxHeight="200">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Recipe">
                                    <Grid Padding="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                                            <TextBlock Text="{x:Bind Machine}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
                                                <Run Text="("/><Run Text="{x:Bind Duration}"/><Run Text="s)"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                                            <TextBlock FontSize="10" Foreground="{StaticResource AccentGreenBrush}">
                                                <Run Text="Out: "/><Run Text="{x:Bind OutputSummary}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
                <Button Content="Compile Target" x:Name="CompileTargetButton" Click="CompileTarget_Click" Style="{StaticResource EndfieldButtonStyle}" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
