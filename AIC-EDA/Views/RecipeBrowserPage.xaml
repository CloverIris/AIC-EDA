<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AIC_EDA.Views.RecipeBrowserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="{StaticResource SurfaceDarkBrush}" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="[ RECIPE_BROWSER ]" Style="{StaticResource BracketTagStyle}"/>
        <TextBox Grid.Row="1" Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                 PlaceholderText="Search..." Margin="0,12"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <Button Content="All" x:Name="FilterAllButton" Click="FilterAll_Click"/>
            <Button Content="Raw" Click="FilterRaw_Click"/>
            <Button Content="Intermediate" Click="FilterIntermediate_Click"/>
            <Button Content="Final" Click="FilterFinal_Click"/>
            <Button Content="Fluid" Click="FilterFluid_Click"/>
            <Button Content="Special" Click="FilterSpecial_Click"/>
        </StackPanel>
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>
            <GridView Grid.Column="0" ItemsSource="{x:Bind ViewModel.Items}" SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
                      SelectionMode="Single" Margin="0,0,16,0">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="100" Height="100" Background="{StaticResource SurfaceCardBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="8">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <FontIcon Glyph="{Binding IconGlyph}" FontSize="24" Foreground="{StaticResource AccentYellowBrush}"/>
                                <TextBlock Text="{Binding Name}" FontSize="11" TextAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
            <StackPanel Grid.Column="1" Spacing="12">
                <Border Background="{StaticResource SurfaceCardBrush}" Padding="16" CornerRadius="4">
                    <TextBlock Text="{x:Bind ViewModel.SelectedItem.Name, Mode=OneWay, FallbackValue='Select an item'}" FontSize="16" FontWeight="Bold"/>
                </Border>
                <Border Background="{StaticResource SurfaceCardBrush}" Padding="12" CornerRadius="4">
                    <TextBlock Text="Production Recipes" Style="{StaticResource CaptionLabelStyle}"/>
                </Border>
                <ListView ItemsSource="{x:Bind ViewModel.ItemRecipes}" Background="Transparent" BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
