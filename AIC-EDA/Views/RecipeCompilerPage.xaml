<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AIC_EDA.Views.RecipeCompilerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AIC_EDA.Views"
    xmlns:vm="using:AIC_EDA.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="NodeTemplate" x:DataType="vm:ProductionNodeViewModel">
            <Grid Padding="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="4"
                        Background="{StaticResource SurfaceElevatedBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind Layer}" FontWeight="Bold" FontSize="12" Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{x:Bind RecipeName}" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                    <TextBlock Text="{x:Bind Inputs}" FontSize="10" Foreground="{StaticResource TextDisabledBrush}"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{x:Bind Count}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="2">
                    <TextBlock Text="{x:Bind PowerConsumption}" FontSize="11" Foreground="{StaticResource AccentOrangeBrush}"/>
                    <TextBlock Text="kW" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                </StackPanel>
                <TextBlock Grid.Column="4" Text="{x:Bind Position}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="RawMaterialTemplate" x:DataType="vm:RawMaterialRequirement">
            <Grid Padding="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentYellowBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Bind ItemName}" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="2">
                    <TextBlock Text="{x:Bind RatePerMinute}" FontSize="13" Foreground="{StaticResource AccentYellowBrush}" FontWeight="SemiBold"/>
                    <TextBlock Text="/min" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="24" Background="{StaticResource SurfaceDarkBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,20">
            <TextBlock Text="[ RTL_SYNTHESIS ]" Style="{StaticResource BracketTagStyle}"/>
            <TextBlock Text="Recipe Compiler" Style="{StaticResource SectionTitleStyle}"/>
            <TextBlock Text="从目标产物反向构建生产树，计算最优设备配置与产线平衡" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Control Panel -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Style="{StaticResource EndfieldComboBoxStyle}"
                      Header="TARGET PRODUCT"
                      PlaceholderText="选择目标产物"
                      ItemsSource="{x:Bind ViewModel.FinalProducts}"
                      SelectedItem="{x:Bind ViewModel.SelectedTarget, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      Margin="0,0,12,0"/>

            <NumberBox Grid.Column="1"
                       Style="{StaticResource EndfieldNumberBoxStyle}"
                       Header="TARGET RATE (/min)"
                       Value="{x:Bind ViewModel.TargetRate, Mode=TwoWay}"
                       Minimum="1"
                       Maximum="10000"
                       SpinButtonPlacementMode="Inline"
                       Margin="0,0,12,0"/>

            <Button Grid.Column="2"
                    Content="COMPILE"
                    Command="{x:Bind ViewModel.CompileCommand}"
                    Style="{StaticResource EndfieldAccentButtonStyle}"
                    VerticalAlignment="Bottom"
                    Margin="0,0,8,0"/>

            <Button Grid.Column="3"
                    Content="Optimize"
                    Command="{x:Bind ViewModel.OptimizeLayoutCommand}"
                    Style="{StaticResource EndfieldOutlineButtonStyle}"
                    VerticalAlignment="Bottom"
                    Margin="0,0,8,0"/>

            <Button Grid.Column="4"
                    Content="Bottleneck"
                    Command="{x:Bind ViewModel.DetectBottlenecksCommand}"
                    Style="{StaticResource EndfieldOutlineButtonStyle}"
                    VerticalAlignment="Bottom"
                    Margin="0,0,8,0"/>

            <Button Grid.Column="5"
                    Content="Layout Designer"
                    Command="{x:Bind ViewModel.SendToLayoutDesignerCommand}"
                    Style="{StaticResource EndfieldAccentButtonStyle}"
                    VerticalAlignment="Bottom"/>
        </Grid>

        <!-- Metrics Cards -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource EndfieldCardStyle}" Padding="16" Margin="0,0,8,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="TOTAL DEVICES" Style="{StaticResource CaptionLabelStyle}"/>
                    <TextBlock Text="{x:Bind ViewModel.TotalMachines, Mode=OneWay}" Style="{StaticResource MetricNumberStyle}" Foreground="{StaticResource AccentCyanBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource EndfieldCardStyle}" Padding="16" Margin="4,0,4,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="TOTAL POWER" Style="{StaticResource CaptionLabelStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.TotalPower, Mode=OneWay}" Style="{StaticResource MetricNumberStyle}" Foreground="{StaticResource AccentOrangeBrush}"/>
                        <TextBlock Text="kW" FontSize="14" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource EndfieldCardStyle}" Padding="16" Margin="8,0,0,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="LAYERS" Style="{StaticResource CaptionLabelStyle}"/>
                    <TextBlock Text="{x:Bind ViewModel.TotalLayers, Mode=OneWay}" Style="{StaticResource MetricNumberStyle}" Foreground="{StaticResource AccentGreenBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status & Results -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Node List -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource SurfaceElevatedBrush}" Padding="12,8" CornerRadius="4,4,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock Text="PRODUCTION NODES" Style="{StaticResource CaptionLabelStyle}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                            <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
                                <Run Text="Devices: "/><Run Text="{x:Bind ViewModel.TotalMachines, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </TextBlock>
                            <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
                                <Run Text="Power: "/><Run Text="{x:Bind ViewModel.TotalPower, Mode=OneWay}" Foreground="{StaticResource AccentOrangeBrush}"/><Run Text=" kW"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource EndfieldCardStyle}" CornerRadius="0,0,4,4" BorderThickness="1,0,1,1">
                    <ListView ItemsSource="{x:Bind ViewModel.Nodes}"
                              ItemTemplate="{StaticResource NodeTemplate}"
                              ItemContainerStyle="{StaticResource EndfieldListViewItemStyle}"
                              Background="Transparent"
                              BorderThickness="0"/>
                </Border>
            </Grid>

            <!-- Right: Raw Materials -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{StaticResource SurfaceElevatedBrush}" Padding="12,8" CornerRadius="4,4,0,0">
                    <TextBlock Text="RAW MATERIALS" Style="{StaticResource CaptionLabelStyle}" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="1" Style="{StaticResource EndfieldCardStyle}" CornerRadius="0,0,4,4" BorderThickness="1,0,1,1">
                    <ListView ItemsSource="{x:Bind ViewModel.RawMaterials}"
                              ItemTemplate="{StaticResource RawMaterialTemplate}"
                              ItemContainerStyle="{StaticResource EndfieldListViewItemStyle}"
                              Background="Transparent"
                              BorderThickness="0"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
