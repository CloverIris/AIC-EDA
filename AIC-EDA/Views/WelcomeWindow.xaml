<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AIC_EDA.Views.WelcomeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AIC_EDA.Views"
    xmlns:vm="using:AIC_EDA.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="AIC-EDA Dashboard">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="{StaticResource SurfaceDarkBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Height="64" Margin="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="AIC-EDA" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                <Border Background="{StaticResource AccentYellowBrush}" CornerRadius="2" Padding="6,2" VerticalAlignment="Center">
                    <TextBlock Text="DASHBOARD" FontSize="10" FontWeight="Bold" Foreground="{StaticResource SurfaceDarkColor}"/>
                </Border>
                <TextBlock Text="Industrial Command Center"
                           FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                           VerticalAlignment="Center" FontFamily="Consolas" Margin="8,0,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                <TextBlock Text="v1.2.0" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Right"/>
                <ToggleSwitch x:Name="ShowOnStartupToggle" Header="Show on startup" IsOn="True"
                              FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- 2x2 Dashboard Grid -->
        <Grid Grid.Row="1" Margin="24,12,24,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Q1: Asset Input & Balanced Layout -->
            <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource SurfaceCardBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="[ Q1 ] ASSET &amp; BALANCE" Style="{StaticResource BracketTagStyle}"/>
                    <StackPanel Grid.Row="1" Spacing="8" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ComboBox x:Name="AssetItemCombo" ItemsSource="{x:Bind ViewModel.AllItems}"
                                      DisplayMemberPath="Name" SelectedItem="{x:Bind ViewModel.SelectedAssetItem, Mode=TwoWay}"
                                      Style="{StaticResource EndfieldComboBoxStyle}" Width="160" PlaceholderText="Select item..."/>
                            <Slider x:Name="AssetQtySlider" Minimum="1" Maximum="100" Value="{x:Bind ViewModel.AssetQuantity, Mode=TwoWay}"
                                    Width="120" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.AssetQuantity, Mode=OneWay}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Width="32"/>
                            <Button Content="Add" Click="AddAsset_Click" Style="{StaticResource EndfieldAccentButtonStyle}" Padding="12,4"/>
                        </StackPanel>
                        <Border Background="{StaticResource SurfaceElevatedBrush}" CornerRadius="4" Padding="8" MaxHeight="100">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="AssetStack" Spacing="4"/>
                            </ScrollViewer>
                        </Border>
                        <Button Content="Clear All" Click="ClearAssets_Click" Style="{StaticResource EndfieldGhostButtonStyle}" HorizontalAlignment="Left" FontSize="11"/>
                    </StackPanel>

                    <!-- Radar chart + sliders -->
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Canvas x:Name="RadarCanvas" Width="100" Height="100" Grid.Column="0" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <Slider Header="Resource" Value="{x:Bind ViewModel.WeightResource, Mode=TwoWay}" Minimum="0" Maximum="100"/>
                            <Slider Header="Processing" Value="{x:Bind ViewModel.WeightProcessing, Mode=TwoWay}" Minimum="0" Maximum="100"/>
                            <Slider Header="Logistics" Value="{x:Bind ViewModel.WeightLogistics, Mode=TwoWay}" Minimum="0" Maximum="100"/>
                            <Slider Header="Power" Value="{x:Bind ViewModel.WeightPower, Mode=TwoWay}" Minimum="0" Maximum="100"/>
                            <Slider Header="Agriculture" Value="{x:Bind ViewModel.WeightAgriculture, Mode=TwoWay}" Minimum="0" Maximum="100"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="3" Spacing="8" Margin="0,8,0,0" VerticalAlignment="Bottom">
                        <Button Content="Calculate Balanced Layout" Click="CalcBalance_Click" Style="{StaticResource EndfieldAccentButtonStyle}" HorizontalAlignment="Stretch"/>
                        <TextBlock Text="{x:Bind ViewModel.BalancedLayoutResult, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" MaxHeight="60"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Q2: Development Priority & RoadMap -->
            <Border Grid.Row="0" Grid.Column="2" Background="{StaticResource SurfaceCardBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="[ Q2 ] PRIORITY &amp; ROADMAP" Style="{StaticResource BracketTagStyle}"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                        <CheckBox Content="Primary" IsChecked="{x:Bind ViewModel.TierPrimarySelected, Mode=TwoWay}" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <CheckBox Content="Intermediate" IsChecked="{x:Bind ViewModel.TierIntermediateSelected, Mode=TwoWay}" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <CheckBox Content="Advanced" IsChecked="{x:Bind ViewModel.TierAdvancedSelected, Mode=TwoWay}" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Button Content="Generate" Click="GenerateRoadMap_Click" Style="{StaticResource EndfieldAccentButtonStyle}" Padding="12,4" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Spacing="6" Margin="0,8,0,0">
                        <TextBlock Text="CHECKLIST" Style="{StaticResource CaptionLabelStyle}"/>
                        <ProgressBar Value="{x:Bind ViewModel.CheckListProgress, Mode=OneWay}" Maximum="1" Background="{StaticResource SurfaceElevatedBrush}" Foreground="{StaticResource AccentGreenBrush}" Height="4"/>
                        <Border Background="{StaticResource SurfaceElevatedBrush}" CornerRadius="4" Padding="8" MaxHeight="120">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="CheckListStack" Spacing="2"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Spacing="6" Margin="0,8,0,0">
                        <TextBlock Text="ROADMAP" Style="{StaticResource CaptionLabelStyle}"/>
                        <Border Background="{StaticResource SurfaceElevatedBrush}" CornerRadius="4" Padding="8">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="RoadMapStack" Spacing="8"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Q3: Multi-Target Optimization -->
            <Border Grid.Row="2" Grid.Column="0" Background="{StaticResource SurfaceCardBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="[ Q3 ] MULTI-TARGET OPTIMIZE" Style="{StaticResource BracketTagStyle}"/>
                    <Border Grid.Row="1" Background="{StaticResource SurfaceElevatedBrush}" CornerRadius="4" Padding="8" MaxHeight="120" Margin="0,8,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="TargetStack" Spacing="4"/>
                        </ScrollViewer>
                    </Border>
                    <Button Grid.Row="2" Content="Analyze Shared Intermediates" Click="AnalyzeShared_Click" Style="{StaticResource EndfieldAccentButtonStyle}" HorizontalAlignment="Stretch" Margin="0,8,0,0"/>
                    <StackPanel Grid.Row="3" Spacing="8" Margin="0,8,0,0" VerticalAlignment="Bottom">
                        <TextBlock Text="{x:Bind ViewModel.UnifiedLayoutSummary, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                        <Border Background="{StaticResource SurfaceElevatedBrush}" CornerRadius="4" Padding="8" MaxHeight="100">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="SharedStack" Spacing="2"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Q4: Production Simulation -->
            <Border Grid.Row="2" Grid.Column="2" Background="{StaticResource SurfaceCardBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="[ Q4 ] SIMULATION &amp; HEATMAP" Style="{StaticResource BracketTagStyle}"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button Content="{x:Bind ViewModel.SimulationStatus, Mode=OneWay}" Click="ToggleSim_Click" Style="{StaticResource EndfieldAccentButtonStyle}" Padding="12,4"/>
                        <TextBlock Text="{x:Bind ViewModel.SimulationStatus, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Row="2" Background="{StaticResource SurfaceElevatedBrush}" CornerRadius="4" Margin="0,8,0,0">
                        <Canvas x:Name="SimCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Border>
                    <TextBlock Grid.Row="3" Text="Simplified throughput simulation. Green = healthy, Yellow = partial load, Red = bottleneck."
                               FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="2" Height="48" Margin="24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Continue to Main Interface  →" Style="{StaticResource EndfieldGhostButtonStyle}" VerticalAlignment="Center" Click="SkipBtn_Click"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Text="ARKNIGHTS: ENDFIELD" FontSize="10" Foreground="{StaticResource TextDisabledBrush}" FontFamily="Consolas"/>
                <TextBlock Text="FAN TOOL" FontSize="10" Foreground="{StaticResource AccentYellowBrush}" Opacity="0.6" FontFamily="Consolas"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
