<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AIC_EDA.Views.WelcomeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AIC_EDA.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="AIC-EDA">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="{StaticResource SurfaceDarkBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Decorative background elements -->
        <Canvas x:Name="DecorCanvas" Grid.RowSpan="3" IsHitTestVisible="False">
            <!-- Grid lines -->
            <Line X1="0" Y1="120" X2="960" Y2="120" Stroke="{StaticResource GridLineMajorBrush}" StrokeThickness="1" Opacity="0.3"/>
            <Line X1="0" Y1="560" X2="960" Y2="560" Stroke="{StaticResource GridLineMajorBrush}" StrokeThickness="1" Opacity="0.3"/>
            <Line X1="280" Y1="120" X2="280" Y2="560" Stroke="{StaticResource GridLineMajorBrush}" StrokeThickness="1" Opacity="0.3"/>
            <Line X1="600" Y1="120" X2="600" Y2="560" Stroke="{StaticResource GridLineMajorBrush}" StrokeThickness="1" Opacity="0.3"/>
            <!-- Decorative pixel blocks -->
            <Rectangle Width="8" Height="8" Fill="{StaticResource AccentGreenBrush}" Opacity="0.4" Canvas.Left="40" Canvas.Top="140"/>
            <Rectangle Width="6" Height="6" Fill="{StaticResource AccentCyanBrush}" Opacity="0.3" Canvas.Left="52" Canvas.Top="152"/>
            <Rectangle Width="10" Height="10" Fill="{StaticResource AccentYellowBrush}" Opacity="0.25" Canvas.Left="860" Canvas.Top="160"/>
            <Rectangle Width="6" Height="6" Fill="{StaticResource AccentGreenBrush}" Opacity="0.35" Canvas.Left="872" Canvas.Top="172"/>
            <Rectangle Width="8" Height="8" Fill="{StaticResource AccentCyanBrush}" Opacity="0.2" Canvas.Left="620" Canvas.Top="520"/>
            <Rectangle Width="12" Height="4" Fill="{StaticResource AccentGreenBrush}" Opacity="0.3" Canvas.Left="200" Canvas.Top="540"/>
        </Canvas>

        <!-- ===== TOP HEADER ===== -->
        <Grid Grid.Row="0" Height="100" Margin="32,24,32,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="AIC-EDA" FontSize="32" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <Border Background="{StaticResource AccentGreenBrush}" CornerRadius="2" Padding="6,2" VerticalAlignment="Center">
                        <TextBlock Text="BETA" FontSize="10" FontWeight="Bold" Foreground="{StaticResource SurfaceDarkColor}"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="Integrated Industry, Integrated Circuit"
                           FontSize="13"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           Margin="0,4,0,0"
                           FontFamily="Consolas"/>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                <TextBlock x:Name="VersionText" Text="v1.0.0" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Right"/>
                <TextBlock Text="WinUI 3 / .NET 8" FontSize="10" Foreground="{StaticResource TextDisabledBrush}" HorizontalAlignment="Right" Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="1" Margin="32,16,32,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: About + Hardware -->
            <Grid Grid.Column="0" Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="[ ABOUT ]" Style="{StaticResource BracketTagStyle}"/>

                <TextBlock Grid.Row="1" Text="AIC-EDA is an automated layout tool for Arknights: Endfield's Integrated Industry Complex. Synthesize recipes, plan spatial layouts, route conveyor belts, and deploy blueprints."
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           Margin="0,0,0,20"/>

                <StackPanel Grid.Row="2" Spacing="12">
                    <TextBlock Text="[ SYSTEM ]" Style="{StaticResource BracketTagStyle}"/>

                    <StackPanel Spacing="8">
                        <StackPanel>
                            <TextBlock Text="PROCESSOR" Style="{StaticResource CaptionLabelStyle}"/>
                            <TextBlock x:Name="CpuText" Text="Detecting..." FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="MEMORY" Style="{StaticResource CaptionLabelStyle}"/>
                            <TextBlock x:Name="MemoryText" Text="Detecting..." FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="GRAPHICS" Style="{StaticResource CaptionLabelStyle}"/>
                            <TextBlock x:Name="GpuText" Text="Detecting..." FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="PLATFORM" Style="{StaticResource CaptionLabelStyle}"/>
                            <TextBlock x:Name="OsText" Text="Detecting..." FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <ToggleSwitch Grid.Row="3"
                              x:Name="ShowOnStartupToggle"
                              Header="Show on startup"
                              IsOn="True"
                              FontSize="11"
                              Foreground="{StaticResource TextTertiaryBrush}"
                              Margin="0,12,0,0"/>
            </Grid>

            <!-- Vertical separator -->
            <Border Grid.Column="0" Width="1" Background="{StaticResource BorderDefaultBrush}" HorizontalAlignment="Right" Margin="0,0,0,0"/>
            <Border Grid.Column="1" Width="1" Background="{StaticResource BorderDefaultBrush}" HorizontalAlignment="Right" Margin="0,0,0,0"/>

            <!-- CENTER: New Project -->
            <Grid Grid.Column="1" Margin="20,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="[ NEW PROJECT ]" Style="{StaticResource BracketTagStyle}"/>

                <StackPanel Grid.Row="1" Spacing="16" Margin="0,8,0,0">
                    <StackPanel Spacing="6">
                        <TextBlock Text="TARGET PRODUCT" Style="{StaticResource CaptionLabelStyle}"/>
                        <ComboBox x:Name="TargetProductCombo"
                                  Style="{StaticResource EndfieldComboBoxStyle}"
                                  HorizontalAlignment="Stretch"
                                  PlaceholderText="Select target item..."/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="TARGET RATE (/min)" Style="{StaticResource CaptionLabelStyle}"/>
                        <NumberBox x:Name="TargetRateBox"
                                   Style="{StaticResource EndfieldNumberBoxStyle}"
                                   Value="60"
                                   Minimum="1"
                                   Maximum="10000"
                                   SpinButtonPlacementMode="Inline"
                                   HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="OPTIMIZATION TARGET" Style="{StaticResource CaptionLabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <RadioButton x:Name="OptArea" Content="Area" GroupName="OptTarget" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <RadioButton x:Name="OptSpeed" Content="Speed" GroupName="OptTarget" Foreground="{StaticResource TextSecondaryBrush}" IsChecked="True"/>
                            <RadioButton x:Name="OptPower" Content="Power" GroupName="OptTarget" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Row="4"
                        x:Name="CreateProjectBtn"
                        Content="CREATE PROJECT"
                        Style="{StaticResource EndfieldAccentButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Margin="0,24,0,0"
                        Click="CreateProjectBtn_Click"/>

                <TextBlock Grid.Row="5"
                           Text="Select a target product and production rate to synthesize an optimal factory layout."
                           FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           TextWrapping="Wrap"
                           LineHeight="18"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,8"/>
            </Grid>

            <!-- RIGHT: Recent Projects -->
            <Grid Grid.Column="2" Margin="20,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="[ RECENT ]" Style="{StaticResource BracketTagStyle}"/>

                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceCardBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Margin="0,8,0,0">
                    <Grid>
                        <ListView x:Name="RecentProjectsList"
                                  Background="Transparent"
                                  ItemContainerStyle="{StaticResource EndfieldListViewItemStyle}"
                                  SelectionMode="Single"
                                  SelectionChanged="RecentProjectsList_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Accent bar -->
                                        <Border Grid.Column="0" Width="3" Background="{StaticResource AccentGreenBrush}" CornerRadius="1" Margin="0,2,8,2"/>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock FontSize="10" Foreground="{StaticResource TextTertiaryBrush}">
                                                    <Run Text="Target: "/><Run Text="{Binding TargetItem}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="10" Foreground="{StaticResource TextTertiaryBrush}">
                                                    <Run Text="{Binding MachineCount}"/><Run Text=" devices"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Text="{Binding LastModified}" FontSize="10" Foreground="{StaticResource TextDisabledBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Empty state -->
                        <TextBlock x:Name="EmptyRecentText"
                                   Text="No recent projects"
                                   FontSize="12"
                                   Foreground="{StaticResource TextDisabledBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Button Grid.Row="2"
                        Content="OPEN EXISTING"
                        Style="{StaticResource EndfieldOutlineButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Margin="0,12,0,0"
                        Click="OpenExistingBtn_Click"/>
            </Grid>
        </Grid>

        <!-- ===== FOOTER ===== -->
        <Grid Grid.Row="2" Height="56" Margin="32,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    x:Name="SkipBtn"
                    Content="Continue to Main Interface  →"
                    Style="{StaticResource EndfieldGhostButtonStyle}"
                    VerticalAlignment="Center"
                    Click="SkipBtn_Click"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Text="ARKNIGHTS: ENDFIELD" FontSize="10" Foreground="{StaticResource TextDisabledBrush}" FontFamily="Consolas"/>
                <TextBlock Text="FAN TOOL" FontSize="10" Foreground="{StaticResource AccentGreenBrush}" Opacity="0.6" FontFamily="Consolas"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
