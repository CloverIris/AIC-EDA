<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <!-- ==========================================================
         AIC-EDA Endfield Theme
         Inspired by Arknights: Endfield official website UI
         Dark theme with neon green / cyan / yellow accents
         ========================================================== -->

    <!-- ========== COLORS ========== -->
    <!-- Primary Accent -->
    <Color x:Key="EndfieldGreen">#39FF14</Color>
    <Color x:Key="EndfieldGreenDim">#39FF1433</Color>
    <Color x:Key="EndfieldGreenGlow">#39FF1466</Color>
    <Color x:Key="EndfieldCyan">#00E5FF</Color>
    <Color x:Key="EndfieldYellow">#FFD600</Color>
    <Color x:Key="EndfieldOrange">#FF6D00</Color>
    <Color x:Key="EndfieldRed">#FF3D00</Color>

    <!-- Surfaces -->
    <Color x:Key="SurfaceDarkColor">#0D0D0D</Color>
    <Color x:Key="SurfaceCardColor">#141414</Color>
    <Color x:Key="SurfaceElevatedColor">#1E1E1E</Color>
    <Color x:Key="SurfaceHoverColor">#2A2A2A</Color>
    <Color x:Key="SurfacePressedColor">#333333</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#B3B3B3</Color>
    <Color x:Key="TextTertiaryColor">#666666</Color>
    <Color x:Key="TextDisabledColor">#404040</Color>

    <!-- Borders -->
    <Color x:Key="BorderDefaultColor">#2A2A2A</Color>
    <Color x:Key="BorderAccentColor">#39FF14</Color>
    <Color x:Key="BorderHoverColor">#4D4D4D</Color>

    <!-- Semantic Status -->
    <Color x:Key="StatusSuccessColor">#39FF14</Color>
    <Color x:Key="StatusWarningColor">#FFD600</Color>
    <Color x:Key="StatusErrorColor">#FF3D00</Color>
    <Color x:Key="StatusInfoColor">#00E5FF</Color>

    <!-- Category Colors for items -->
    <Color x:Key="CategoryRawColor">#9E9E9E</Color>
    <Color x:Key="CategoryIntermediateColor">#FFD600</Color>
    <Color x:Key="CategoryFinalColor">#39FF14</Color>
    <Color x:Key="CategoryMachineColor">#00E5FF</Color>
    <Color x:Key="CategoryPowerColor">#FF6D00</Color>

    <!-- ========== BRUSHES ========== -->
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource EndfieldGreen}"/>
    <SolidColorBrush x:Key="AccentGreenDimBrush" Color="{StaticResource EndfieldGreenDim}"/>
    <SolidColorBrush x:Key="AccentGreenGlowBrush" Color="{StaticResource EndfieldGreenGlow}"/>
    <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource EndfieldCyan}"/>
    <SolidColorBrush x:Key="AccentYellowBrush" Color="{StaticResource EndfieldYellow}"/>
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource EndfieldOrange}"/>
    <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource EndfieldRed}"/>

    <SolidColorBrush x:Key="SurfaceDarkBrush" Color="{StaticResource SurfaceDarkColor}"/>
    <SolidColorBrush x:Key="SurfaceCardBrush" Color="{StaticResource SurfaceCardColor}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}"/>
    <SolidColorBrush x:Key="SurfacePressedBrush" Color="{StaticResource SurfacePressedColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>

    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefaultColor}"/>
    <SolidColorBrush x:Key="BorderAccentBrush" Color="{StaticResource BorderAccentColor}"/>
    <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource BorderHoverColor}"/>

    <SolidColorBrush x:Key="StatusSuccessBrush" Color="{StaticResource StatusSuccessColor}"/>
    <SolidColorBrush x:Key="StatusWarningBrush" Color="{StaticResource StatusWarningColor}"/>
    <SolidColorBrush x:Key="StatusErrorBrush" Color="{StaticResource StatusErrorColor}"/>
    <SolidColorBrush x:Key="StatusInfoBrush" Color="{StaticResource StatusInfoColor}"/>

    <SolidColorBrush x:Key="CategoryRawBrush" Color="{StaticResource CategoryRawColor}"/>
    <SolidColorBrush x:Key="CategoryIntermediateBrush" Color="{StaticResource CategoryIntermediateColor}"/>
    <SolidColorBrush x:Key="CategoryFinalBrush" Color="{StaticResource CategoryFinalColor}"/>
    <SolidColorBrush x:Key="CategoryMachineBrush" Color="{StaticResource CategoryMachineColor}"/>
    <SolidColorBrush x:Key="CategoryPowerBrush" Color="{StaticResource CategoryPowerColor}"/>

    <!-- Glow effect brush (used for borders/shadows) -->
    <SolidColorBrush x:Key="GlowBrush" Color="{StaticResource EndfieldGreenGlow}"/>

    <!-- Grid line brush for canvas -->
    <SolidColorBrush x:Key="GridLineBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="GridLineMajorBrush" Color="#2A2A2A"/>

    <!-- ========== TEXT STYLES ========== -->
    <!-- Display Title: large bold title like Endfield website -->
    <Style x:Key="DisplayTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="36"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="LineHeight" Value="44"/>
    </Style>

    <!-- Section Title -->
    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- Bracket Tag: [ TAG_NAME ] style -->
    <Style x:Key="BracketTagStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="CharacterSpacing" Value="40"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- Caption / Label -->
    <Style x:Key="CaptionLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
    </Style>

    <!-- Large Metric Number -->
    <Style x:Key="MetricNumberStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontWeight" Value="Light"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- ========== BUTTON STYLES ========== -->
    <!-- Primary Accent Button -->
    <Style x:Key="EndfieldAccentButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentGreenBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource SurfaceDarkColor}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentGreenBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- Secondary Outline Button -->
    <Style x:Key="EndfieldOutlineButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="16,8"/>
    </Style>

    <!-- Ghost Button (text only with arrow) -->
    <Style x:Key="EndfieldGhostButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- ========== CARD / BORDER STYLES ========== -->
    <!-- Standard dark card -->
    <Style x:Key="EndfieldCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <!-- Elevated card with accent border -->
    <Style x:Key="EndfieldAccentCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderAccentBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <!-- ========== NAVIGATION VIEW CUSTOMIZATION ========== -->
    <!-- Override NavigationView colors to match Endfield theme -->
    <Style x:Key="EndfieldNavigationViewStyle" TargetType="muxc:NavigationView">
        <Setter Property="Background" Value="{StaticResource SurfaceDarkBrush}"/>
        <Setter Property="IsPaneToggleButtonVisible" Value="False"/>
        <Setter Property="IsBackButtonVisible" Value="Collapsed"/>
        <Setter Property="PaneDisplayMode" Value="LeftCompact"/>
        <Setter Property="OpenPaneLength" Value="200"/>
        <Setter Property="CompactPaneLength" Value="56"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <!-- ========== LIST VIEW ITEM CONTAINER ========== -->
    <Style x:Key="EndfieldListViewItemStyle" TargetType="ListViewItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <!-- ========== TEXT BOX STYLES ========== -->
    <Style x:Key="EndfieldTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource SurfaceElevatedBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="SelectionHighlightColor" Value="{StaticResource AccentGreenBrush}"/>
    </Style>

    <!-- ========== COMBO BOX STYLES ========== -->
    <Style x:Key="EndfieldComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource SurfaceElevatedBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>

    <!-- ========== NUMBER BOX STYLES ========== -->
    <Style x:Key="EndfieldNumberBoxStyle" TargetType="muxc:NumberBox">
        <Setter Property="Background" Value="{StaticResource SurfaceElevatedBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <!-- ========== INFO BAR STYLES ========== -->
    <Style x:Key="EndfieldInfoBarStyle" TargetType="muxc:InfoBar">
        <Setter Property="Background" Value="{StaticResource SurfaceElevatedBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <!-- ========== TOGGLE SWITCH ========== -->
    <Style x:Key="EndfieldToggleSwitchStyle" TargetType="ToggleSwitch">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

</ResourceDictionary>
