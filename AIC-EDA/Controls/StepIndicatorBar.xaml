<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="AIC_EDA.Controls.StepIndicatorBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="40">

    <Grid Background="{StaticResource SurfaceCardBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
        <StackPanel x:Name="StepsContainer" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"/>
    </Grid>
</UserControl>
